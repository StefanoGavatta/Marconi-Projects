---
---

<header class="fixed top-0 left-0 w-full z-50 bg-[#0f172a]/80 backdrop-blur-md border-b border-gray-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="flex-shrink-0">
        <a href="/" class="text-white font-bold text-xl tracking-wide">
          Mario<span class="text-[#3b82f6]">Rossi</span>
        </a>
      </div>
      
      <!-- Desktop menu -->
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-8">
          <a href="#studi" class="text-gray-300 hover:text-white hover:underline hover:decoration-[#3b82f6] hover:decoration-2 underline-offset-4 transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#3b82f6] rounded-sm px-1">Studi</a>
          <a href="#esperienze" class="text-gray-300 hover:text-white hover:underline hover:decoration-[#3b82f6] hover:decoration-2 underline-offset-4 transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#3b82f6] rounded-sm px-1">Esperienze</a>
          <a href="#progetti" class="text-gray-300 hover:text-white hover:underline hover:decoration-[#3b82f6] hover:decoration-2 underline-offset-4 transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#3b82f6] rounded-sm px-1">Progetti</a>
        </div>
      </div>
      
      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button id="mobile-menu-btn" type="button" aria-label="Apri menu principale" class="text-gray-400 hover:text-[#3b82f6] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#3b82f6] rounded-md p-2" aria-controls="mobile-menu" aria-expanded="false">
          <span class="sr-only">Apri menu principale</span>
          <svg class="h-7 w-7" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden md:hidden bg-[#0f172a] border-b border-gray-800 absolute w-full origin-top transition-all duration-300">
    <div class="px-4 pt-2 pb-4 space-y-2 flex flex-col">
      <a href="#studi" class="mobile-link text-gray-300 hover:text-white hover:bg-gray-800 block px-3 py-3 rounded-md text-base font-medium">Studi</a>
      <a href="#esperienze" class="mobile-link text-gray-300 hover:text-white hover:bg-gray-800 block px-3 py-3 rounded-md text-base font-medium">Esperienze</a>
      <a href="#progetti" class="mobile-link text-gray-300 hover:text-white hover:bg-gray-800 block px-3 py-3 rounded-md text-base font-medium">Progetti</a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-link');

  // Toggle dropdown on button click
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close dropdown when a link is clicked
  links.forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>