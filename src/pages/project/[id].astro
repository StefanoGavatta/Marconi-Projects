---
import BaseLayout from '../../layouts/BaseLayout.astro';
import projectsData from '../../data/projects.json';

export async function getStaticPaths() {
  return projectsData.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.name} - Progetto`} description={project.description} image={project.images && project.images.length > 0 ? project.images[0] : undefined}>
  <div class="py-12 ">
    <!-- Back Button -->
    <a href="/#progetti" aria-label="Torna ai Progetti" class="inline-flex items-center text-gray-400 hover:text-blue-400 mb-8 transition-colors font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded p-1">
      <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Torna ai Progetti
    </a>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start mt-4">
      
      <!-- Sezione Info (Sinistra su Desktop, Sotto su Mobile) -->
      <div class="order-2 md:order-1 flex flex-col h-full bg-[#1e293b] border border-blue-500/20 rounded-2xl p-8 backdrop-blur-sm hover:shadow-md transition-shadow">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="inline-block px-3 py-1 bg-gray-800 border border-gray-700 text-gray-300 rounded text-xs font-bold uppercase tracking-widest">
            {project.category}
          </span>
          
          {project.status === 'completato' ? (
            <span class="inline-block px-3 py-1 bg-blue-600 border border-blue-500 text-white rounded text-xs font-bold uppercase tracking-widest">Completato</span>
          ) : (
            <span class="inline-block px-3 py-1 bg-transparent border border-gray-500 text-gray-400 rounded text-xs font-bold uppercase tracking-widest">In corso</span>
          )}
          
          <span class="inline-block px-3 py-1 bg-blue-500/10 text-blue-400 rounded text-xs font-bold uppercase tracking-widest ml-auto">
            Classe {project.year}
          </span>
        </div>

        <h1 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">
          {project.name}
        </h1>

        <div class="prose prose-invert max-w-none text-gray-300 text-lg mb-8 leading-relaxed">
          <p>{project.description}</p>
        </div>


        <!-- Collaboratori -->
        {project.collaborators && project.collaborators.length > 0 && (
          <div class="mb-8">
            <h3 class="text-xl font-semibold text-white mb-4">Collaboratori</h3>
            <div class="flex flex-wrap gap-2">
              {project.collaborators.map((collab: string) => (
                <div class="flex items-center gap-2 px-3 py-1.5 bg-[#0f172a] rounded-full border border-gray-700">
                  <div class="w-6 h-6 rounded-full bg-blue-600 flex items-center justify-center text-xs font-bold text-white uppercase">
                    {collab.charAt(0)}
                  </div>
                  <span class="text-sm text-gray-300 font-medium whitespace-nowrap">{collab}</span>
                </div>
              ))}
            </div>
          </div>
        )}
        
        <!-- Strumenti Utilizzati -->
        <div class="mb-8">
          <h3 class="text-xl font-semibold text-white mb-4">Strumenti Utilizzati</h3>
          <div class="flex flex-wrap gap-2">
            {project.tools.map((tool: string) => (
              <span class="px-4 py-1.5 bg-blue-500/20 text-blue-300 rounded-full text-sm font-medium border border-blue-500/30">
                {tool}
              </span>
            ))}
          </div>
        </div>

        <div class="mt-auto pt-8 border-t border-gray-800">
          <div class="flex flex-wrap gap-4">
            {project.githubUrl && (
              <a 
                href={project.githubUrl} 
                aria-label={`Apri codice di ${project.name} su GitHub`}
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center px-6 py-3 bg-[#0f172a] border-2 border-blue-500 text-white rounded-lg hover:bg-blue-600 hover:border-blue-600 hover:shadow-md transition-all font-semibold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#1e293b]"
              >
                <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
                Apri su GitHub
              </a>
            )}
            
            {project.demoUrl && (
              <a 
                href={project.demoUrl} 
                aria-label={`Vai alla demo di ${project.name}`}
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center px-6 py-3 bg-[#0f172a] border-2 border-blue-500 text-white rounded-lg hover:bg-blue-600 hover:border-blue-600 hover:shadow-md transition-all font-semibold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#1e293b]"
              >
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                Vai alla Demo
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Image Gallery (Destra su Desktop, Sopra su Mobile) -->
      <div class="order-1 md:order-2 flex flex-col gap-6">
        {project.images && project.images.length > 0 ? (
          project.images.map((imgUrl: string, index: number) => (
            <div class="relative aspect-video rounded-2xl overflow-hidden shadow-2xl border border-blue-500/20 group">
              {isVideo ? (
                <video src={mediaUrl} muted loop playsinline class="w-full h-full object-cover transition-transform duration-700 hover:scale-105 lightbox-trigger cursor-pointer"></video>
              ) : (
                <img src={mediaUrl} alt={`Schermata ${index + 1} del progetto ${project.name}`} width="1280" height="720" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 hover:scale-105 lightbox-trigger cursor-pointer" />
              )}
              )}
              {index === 0 && (
                <>
                  <!-- Overlay per la prima immagine (Copertina) -->
                  <div class="absolute inset-0 bg-gradient-to-t from-[#0f172a]/90 via-[#0f172a]/30 to-transparent pointer-events-none"></div>
                  <!-- Title Overlay -->
                  <div class="absolute bottom-6 left-6 right-6 pointer-events-none">
                    <h2 class="text-2xl md:text-3xl font-bold text-white drop-shadow-md">{project.name}</h2>
                    <div class="mt-2 h-1 w-16 bg-blue-500 rounded"></div>
                  </div>
                </>
              )}
            </div>
          ))
        ) : (
          <div class="relative aspect-video rounded-2xl overflow-hidden shadow-2xl border border-blue-500/20 flex flex-col items-center justify-center bg-gray-800 text-gray-500 text-xl font-medium">
            Immagine principale non disponibile
            <!-- Title Overlay fallback -->
            <div class="absolute bottom-6 left-6 right-6">
              <h2 class="text-2xl md:text-3xl font-bold text-white drop-shadow-md">{project.name}</h2>
              <div class="mt-2 h-1 w-16 bg-blue-500 rounded"></div>
            </div>
          </div>
        )}
      </div>


    </div>
  </div>

  <!-- Lightbox Modal -->
  <dialog id="lightbox" class="fixed inset-0 z-[100] w-full h-full bg-black/90 backdrop-blur-sm p-0 m-0 border-none items-center justify-center hidden open:flex">
    <button id="lightbox-close" class="absolute top-6 right-6 text-white hover:text-blue-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded p-2 z-50 bg-[#0f172a]/50" aria-label="Chiudi ingrandimento">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <img id="lightbox-img" src="" alt="Immagine ingrandita" class="max-w-[95vw] max-h-[90vh] object-contain rounded-lg shadow-2xl" />
  </dialog>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const triggers = document.querySelectorAll('.lightbox-trigger');
      const lightbox = document.getElementById('lightbox');
      const lightboxImg = document.getElementById('lightbox-img');
      const closeBtn = document.getElementById('lightbox-close');

      if (!lightbox || !lightboxImg) return;

      const lightboxVideo = document.getElementById('lightbox-video');
      
      triggers.forEach(function (trigger) {
        trigger.addEventListener('click', function (e) {
          const el = e.currentTarget;
          if (!el) return;
          
          const isVideo = el.tagName.toLowerCase() === 'video';
          // @ts-ignore
          const mediaSrc = el.src || el.currentSrc;
          
          if (mediaSrc) {
            if (isVideo) {
              lightboxImg.classList.add('hidden');
              lightboxImg.src = '';
              lightboxVideo.classList.remove('hidden');
              // @ts-ignore
              lightboxVideo.src = mediaSrc;
              // @ts-ignore
              lightboxVideo.play();
            } else {
              lightboxVideo.classList.add('hidden');
              // @ts-ignore
              lightboxVideo.pause();
              // @ts-ignore
              lightboxVideo.src = '';
              lightboxImg.classList.remove('hidden');
              // @ts-ignore
              lightboxImg.src = mediaSrc;
            }
            
            if (typeof lightbox.showModal === 'function') {
              // @ts-ignore
              lightbox.showModal();
            }
            lightbox.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
          }
        });
      });

      var closeModal = function () {
        if (typeof lightbox.close === 'function') {
          // @ts-ignore
          lightbox.close();
        }
        lightbox.classList.add('hidden');
        document.body.style.overflow = '';
        // Stop video playback on close
        if (lightboxVideo && !lightboxVideo.paused) {
           // @ts-ignore
           lightboxVideo.pause();
        }
      };

      if (closeBtn) closeBtn.addEventListener('click', closeModal);

      // Chiudi al click fuori dall'immagine (sul backdrop)
      lightbox.addEventListener('click', function (e) {
        if (e.target === lightbox) {
          closeModal();
        }
      });
    });
  </script>
</BaseLayout>
