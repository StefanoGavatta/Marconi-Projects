---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectTimeline from '../components/ProjectTimeline.astro';
import profileData from '../data/profile.json';
import educationData from '../data/education.json';
import experiencesData from '../data/experiences.json';
---

<BaseLayout title={profileData.name + " - Portfolio"}>
  <!-- HERO SECTION -->
  <section id="hero" class="relative overflow-hidden min-h-[70vh] flex py-16 items-center bg-gradient-to-b from-[#0f172a] to-[#1e293b] -mt-8 pt-16 px-4 rounded-b-3xl mb-16 shadow-2xl ">
    <div class="max-w-6xl mx-auto w-full flex flex-col md:flex-row items-center gap-12 z-10">
      {profileData.avatarUrl && (
        <div class="w-48 h-48 md:w-64 md:h-64 flex-shrink-0 relative">
          <div class="absolute inset-0 bg-blue-500 rounded-full hidden opacity-20 "></div>
          <img src={profileData.avatarUrl} alt={profileData.name} class="relative w-full h-full object-cover rounded-full border-4 border-blue-500/30 shadow-xl" />
        </div>
      )}
      
      <div class="text-center md:text-left flex-grow">
        <h1 class="text-5xl md:text-7xl font-bold text-white tracking-tight mb-4">
          {profileData.name}
        </h1>
        <h2 class="text-2xl md:text-3xl text-blue-400 font-medium mb-2">
          {profileData.title}
        </h2>
        <h3 class="text-lg md:text-xl text-blue-400 opacity-80 mb-8">
          {profileData.school}
        </h3>
        
        <div class="flex items-center justify-center md:justify-start gap-6">
          <a href={profileData.github} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white  transition-transform duration-200">
            <span class="sr-only">GitHub</span>
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
          </a>
          <a href={profileData.linkedin} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#0a66c2]  transition-transform duration-200">
            <span class="sr-only">LinkedIn</span>
            <!-- Simple linkedin path -->
            <svg class="w-8 h-8 pointer-events-none" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" /></svg>
          </a>
          <a href={`mailto:${profileData.email}`} class="text-gray-400 hover:text-blue-400  transition-transform duration-200">
            <span class="sr-only">Email</span>
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STUDI & CERTIFICAZIONI SECTION -->
  <section id="studi" class="py-16 scroll-mt-20">
    <div class="flex items-center gap-4 mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white whitespace-nowrap">Studi & Certificazioni</h2>
      <div class="h-1 flex-grow bg-blue-500/30 rounded"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Studi -->
      <div class="space-y-6">
        <h3 class="text-2xl font-semibold text-blue-300">Formazione Scolastica</h3>
        {educationData.years.map((item) => (
          <div class="bg-[#1e293b] border border-blue-500/20 rounded-2xl p-6 hover:border-blue-500/50 transition-colors">
            <span class="inline-block px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full text-sm font-medium mb-3">
              Anno: {item.year}
            </span>
            <h4 class="text-xl font-bold text-white mb-1">{item.institute}</h4>
            <p class="text-gray-400">{item.address}</p>
          </div>
        ))}
      </div>

      <!-- Certificazioni -->
      <div class="space-y-6">
        <h3 class="text-2xl font-semibold text-blue-300">Certificazioni</h3>
        {educationData.certifications.map((cert) => (
          <div class="bg-[#1e293b] border border-blue-500/20 rounded-2xl p-6 hover:border-blue-500/50 transition-colors">
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="inline-block px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full text-sm font-medium">
                {cert.year}
              </span>
              <span class="inline-block px-3 py-1 bg-gray-700 text-gray-300 rounded-full text-sm font-medium">
                {cert.type}
              </span>
            </div>
            <h4 class="text-xl font-bold text-white">{cert.name}</h4>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ESPERIENZE SECTION -->
  <section id="esperienze" class="py-16 scroll-mt-20 " >
    <div class="flex items-center gap-4 mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white whitespace-nowrap">Esperienze</h2>
      <div class="h-1 flex-grow bg-blue-500/30 rounded"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {experiencesData.map((exp) => (
        <a href={`/experience/${exp.id}`} aria-label={`Vai all'esperienza presso ${exp.company}`} class="block group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded-2xl">
          <div class="bg-[#1e293b] border border-blue-500/20 rounded-2xl p-6 h-full flex flex-col  hover:border-blue-500/50 hover:shadow-md transition-all cursor-pointer shadow-lg">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-16 h-16 bg-[#0f172a] border border-blue-500/30 rounded-xl p-2 flex items-center justify-center flex-shrink-0">
                {exp.logoUrl ? (
                  <img src={exp.logoUrl} alt={`Logo ${exp.company}`} width="48" height="48" loading="lazy" decoding="async" class="w-full h-full object-contain" />
                ) : (
                  <svg class="w-8 h-8 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                )}
              </div>
              <div>
                <h3 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors">{exp.company}</h3>
                <p class="text-gray-400 text-sm">{exp.role}</p>
              </div>
            </div>
            
            <div class="mt-auto pt-4 border-t border-gray-800 flex justify-between items-center">
              <span class="text-sm text-gray-500">{exp.period}</span>
              <span class="inline-block px-3 py-1 bg-blue-500/10 text-blue-300 rounded-full text-xs font-semibold uppercase tracking-wider">
                {exp.type}
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- PROGETTI SECTION -->
  <section id="progetti" class="py-16 scroll-mt-20 " >
    <div class="flex items-center gap-4 mb-4">
      <h2 class="text-3xl md:text-4xl font-bold text-white whitespace-nowrap">Progetti</h2>
      <div class="h-1 flex-grow bg-blue-500/30 rounded"></div>
    </div>
    <p class="text-gray-400 mb-12">I miei progetti realizzati durante il percorso di studi, sia personali che scolastici.</p>

    <!-- Project Timeline (Filtri + Timeline + Griglia per anno) -->
    <ProjectTimeline />
  </section>
</BaseLayout>

<style>
  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  . {
    animation: fadeInUp 0.8s ease-out forwards;
  }
</style>
